{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "FullAccessToSchoolBuckets",
            "Effect": "Allow",
            "Action": [
                "s3:*"
            ],
            "Resource": [
                "arn:aws:s3:::*school*",
                "arn:aws:s3:::*school*/*"
            ]
        }
    ]
}